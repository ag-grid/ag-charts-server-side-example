{
  "name": "ag-charts-server-side-example",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "external/ag-charts-server-side-example",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["ag-charts-server-side:build", "ag-charts-community:build"],
      "options": {
        "cwd": "external/ag-charts-server-side-example",
        "commands": ["tsx examples/01-basic-render.ts", "tsx examples/02-jpeg-output.ts"]
      }
    },
    "docker": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "ag-charts-types:pack",
        "ag-charts-locale:pack",
        "ag-charts-core:pack",
        "ag-charts-community:pack",
        "ag-charts-enterprise:pack",
        "ag-charts-server-side:pack"
      ],
      "options": {
        "command": "./external/ag-charts-server-side-example/.docker/run.sh basic --skip-build"
      }
    },
    "docker:jpeg": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "ag-charts-types:pack",
        "ag-charts-locale:pack",
        "ag-charts-core:pack",
        "ag-charts-community:pack",
        "ag-charts-enterprise:pack",
        "ag-charts-server-side:pack"
      ],
      "options": {
        "command": "./external/ag-charts-server-side-example/.docker/run.sh jpeg --skip-build"
      }
    },
    "docker:server": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "ag-charts-types:pack",
        "ag-charts-locale:pack",
        "ag-charts-core:pack",
        "ag-charts-community:pack",
        "ag-charts-enterprise:pack",
        "ag-charts-server-side:pack"
      ],
      "cache": false,
      "options": {
        "command": "./external/ag-charts-server-side-example/.docker/run.sh server --skip-build"
      }
    }
  },
  "tags": ["example"],
  "implicitDependencies": ["ag-charts-community", "ag-charts-server-side"]
}
